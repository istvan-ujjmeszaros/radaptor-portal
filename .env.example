# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Callback URL (must match GitHub OAuth App settings)
GITHUB_CALLBACK_URL=http://localhost:8020/auth/callback

# Secret key for HMAC license signing (share with Radaptor)
LICENSE_SECRET=generate_a_strong_random_secret_here

# App URL
APP_URL=http://localhost:8020
