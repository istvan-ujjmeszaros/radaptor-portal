{
  "webpages": [
    {
      "path": "/admin/",
      "layout": "admin_default",
      "attributes": {
        "title": "Portal admin",
        "description": "Portal administration dashboard."
      },
      "acl": {
        "inherit": true,
        "usergroups": []
      },
      "slots": {
        "content": [
          {
            "widget": "PlainHtml",
            "settings": {
              "content": "<div class=\"card card-hover email-admin-welcome\"><div class=\"card-body\"><h2 class=\"h3 mb-3\">Welcome to Radaptor Portal</h2><p class=\"mb-2\">This demo ships with a polished public landing surface, a technical comparison page, and a placeholder request-access flow.</p><p class=\"mb-0\">Use the side menu to manage users, roles, resources, and portal content.</p></div></div>"
            }
          },
          {
            "widget": "EmailQueueStats"
          }
        ]
      }
    }
  ]
}
