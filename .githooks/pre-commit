#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$PROJECT_ROOT"

DOCKER_SERVICE="${RADAPTOR_DOCKER_PHP_SERVICE:-php}"
DOCKER_CONTAINER=""

has_workspace_local_override() {
	local override_file=""

	for override_file in \
		"$PROJECT_ROOT/radaptor.local.json" \
		"$PROJECT_ROOT/radaptor.local.lock.json"
	do
		if [ ! -f "$override_file" ]; then
			continue
		fi

		if grep -q '/workspace/packages-dev/' "$override_file"; then
			return 0
		fi
	done

	return 1
}

find_running_docker_container() {
	local working_dir="$1"
	local preferred_container=""
	local fallback_container=""
	local container_name=""
	local config_files=""

	if ! command -v docker >/dev/null 2>&1; then
		return 1
	fi

	while IFS=$'\t' read -r container_name config_files; do
		if [ -z "$container_name" ]; then
			continue
		fi

		if [ -z "$fallback_container" ]; then
			fallback_container="$container_name"
		fi

		if [[ "$config_files" == *"docker-compose.packages-dev.yml"* ]]; then
			preferred_container="$container_name"
			break
		fi
	done < <(
		docker ps \
			--filter "label=com.docker.compose.project.working_dir=$working_dir" \
			--filter "label=com.docker.compose.service=$DOCKER_SERVICE" \
			--format '{{.Names}}\t{{.Label "com.docker.compose.project.config_files"}}'
	)

	if [ -n "$preferred_container" ]; then
		printf '%s\n' "$preferred_container"
		return 0
	fi

	if [ -n "$fallback_container" ]; then
		printf '%s\n' "$fallback_container"
		return 0
	fi

	return 1
}

if ! DOCKER_CONTAINER="$(find_running_docker_container "$PROJECT_ROOT")"; then
	echo -e "${RED}Docker service '$DOCKER_SERVICE' is not running or Docker Compose is unavailable.${NC}"
	if has_workspace_local_override; then
		echo -e "${YELLOW}Workspace package-dev local overrides are active, so host-side fallback is not supported.${NC}"
	fi
	echo -e "${YELLOW}Start the supported php container for this repo and retry.${NC}"
	exit 1
fi

echo -e "${YELLOW}Running pre-commit checks inside Docker container: $DOCKER_CONTAINER${NC}"

if [ -x "$PROJECT_ROOT/bin/check-local-override-state.sh" ]; then
	echo -e "${YELLOW}Checking local override guardrails...${NC}"
	docker exec "$DOCKER_CONTAINER" bash -lc "cd /app && ./bin/check-local-override-state.sh"
fi

STAGED_FILES=()
while IFS= read -r -d '' staged_file; do
	STAGED_FILES+=("$staged_file")
done < <(git diff --cached --name-only -z --diff-filter=ACM -- '*.php')

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
	exit 0
fi

echo -e "${YELLOW}Regenerating autoloader map...${NC}"

if ! docker exec "$DOCKER_CONTAINER" bash -lc "cd /app && radaptor build:autoloader"; then
	echo -e "${RED}Failed to regenerate autoloader map.${NC}"
	echo -e "${YELLOW}Run manually: radaptor build:autoloader${NC}"
	exit 1
fi

echo -e "${YELLOW}Running PHP-CS-Fixer on staged files...${NC}"

if ! docker exec "$DOCKER_CONTAINER" bash -lc \
	"cd /app && ./php-cs-fixer.sh --config=.php-cs-fixer.php --quiet --path-mode=intersection -- \"\$@\"" \
	bash "${STAGED_FILES[@]}"; then
	echo -e "${RED}PHP-CS-Fixer encountered errors. Please fix them and try again.${NC}"
	exit 1
fi

git add -- "${STAGED_FILES[@]}"

echo -e "${GREEN}PHP-CS-Fixer completed successfully!${NC}"

if git diff --cached --name-only | grep -qE 'migrations/.*\.php$'; then
	if ! git diff --cached --name-only | grep -q '__db_schema_data__.php'; then
		echo ""
		echo -e "${YELLOW}┌──────────────────────────────────────────────────────┐${NC}"
		echo -e "${YELLOW}│ WARNING: Migration committed without schema update   │${NC}"
		echo -e "${YELLOW}├──────────────────────────────────────────────────────┤${NC}"
		echo -e "${YELLOW}│ A migration file is staged but __db_schema_data__.  │${NC}"
		echo -e "${YELLOW}│ php is not. Consider running:                       │${NC}"
		echo -e "${YELLOW}│                                                      │${NC}"
		echo -e "${YELLOW}│   radaptor migrate:run                               │${NC}"
		echo -e "${YELLOW}│   radaptor build:db                                  │${NC}"
		echo -e "${YELLOW}│   git add generated/__db_schema_data__.php           │${NC}"
		echo -e "${YELLOW}│                                                      │${NC}"
		echo -e "${YELLOW}│ Committing anyway (this is just a warning).         │${NC}"
		echo -e "${YELLOW}└──────────────────────────────────────────────────────┘${NC}"
		echo ""
	fi
fi
