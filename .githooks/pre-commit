#!/bin/bash

# PHP-CS-Fixer pre-commit hook
# Automatically formats PHP files before committing
#
# Environment variables:
#   RADAPTOR_DOCKER_PHP_SERVICE - Docker service name for PHP container (default: php)
#                                 Example: "php" or "my-php-service"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the project root directory
PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$PROJECT_ROOT"

RELATIVE_FIXER_BIN="tools/php-cs-fixer"
PHP_CS_FIXER_WRAPPER="$PROJECT_ROOT/php-cs-fixer.sh"

DOCKER_SERVICE="${RADAPTOR_DOCKER_PHP_SERVICE:-php}"
RUN_IN_DOCKER=0

if command -v docker >/dev/null 2>&1; then
	if docker compose -f docker-compose-dev.yml ps "$DOCKER_SERVICE" 2>/dev/null | grep -q "Up"; then
		RUN_IN_DOCKER=1
	fi
fi

if [ -n "$RADAPTOR_DOCKER_PHP_SERVICE" ] && [ $RUN_IN_DOCKER -eq 0 ]; then
	echo -e "${RED}Docker service '$DOCKER_SERVICE' is not running or Docker Compose is unavailable.${NC}"
	echo -e "${YELLOW}Start it via: docker compose -f docker-compose-dev.yml up -d $DOCKER_SERVICE${NC}"
	exit 1
fi

if [ $RUN_IN_DOCKER -eq 1 ]; then
	echo -e "${YELLOW}Running PHP-CS-Fixer inside Docker service: $DOCKER_SERVICE${NC}"
else
	echo -e "${YELLOW}Docker service '$DOCKER_SERVICE' not detected. Running PHP-CS-Fixer locally.${NC}"
fi

if [ ! -x "$PHP_CS_FIXER_WRAPPER" ]; then
	echo -e "${RED}PHP-CS-Fixer wrapper is missing ($PHP_CS_FIXER_WRAPPER).${NC}"
	exit 1
fi

# Get list of staged PHP files
STAGED_FILES=()

while IFS= read -r -d '' staged_file; do
	STAGED_FILES+=("$staged_file")
done < <(git diff --cached --name-only -z --diff-filter=ACM -- '*.php')

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
	# No PHP files staged, allow commit
	exit 0
fi

echo -e "${YELLOW}Regenerating autoloader map...${NC}"

run_build_autoloader() {
	if [ $RUN_IN_DOCKER -eq 1 ]; then
		docker compose -f docker-compose-dev.yml exec -T "$DOCKER_SERVICE" bash -lc "cd /app && radaptor build:autoloader"
	else
		if command -v radaptor >/dev/null 2>&1; then
			radaptor build:autoloader
		elif [ -f "$PROJECT_ROOT/radaptor.php" ]; then
			php "$PROJECT_ROOT/radaptor.php" build:autoloader
		else
			return 127
		fi
	fi
}

if ! run_build_autoloader; then
	echo -e "${RED}Failed to regenerate autoloader map.${NC}"
	echo -e "${YELLOW}Run manually: radaptor build:autoloader${NC}"
	exit 1
fi

if [ -f "generated/__autoload__.php" ]; then
	git add generated/__autoload__.php
fi

echo -e "${YELLOW}Running PHP-CS-Fixer on staged files...${NC}"

# Function to run PHP-CS-Fixer on all staged files at once
run_fixer() {
	if [ $RUN_IN_DOCKER -eq 1 ]; then
		docker compose -f docker-compose-dev.yml exec -T "$DOCKER_SERVICE" bash -lc \
			"cd /app && ./php-cs-fixer.sh --config=.php-cs-fixer.php --quiet --path-mode=intersection -- \"\$@\"" \
			bash "${STAGED_FILES[@]}"
	else
		"$PHP_CS_FIXER_WRAPPER" --config=.php-cs-fixer.php --quiet --path-mode=intersection -- "${STAGED_FILES[@]}"
	fi
}

# Run PHP-CS-Fixer on staged files
if ! run_fixer; then
	echo -e "${RED}PHP-CS-Fixer encountered errors. Please fix them and try again.${NC}"
	exit 1
fi

git add -- "${STAGED_FILES[@]}"

echo -e "${GREEN}PHP-CS-Fixer completed successfully!${NC}"

# Migration schema check
# If migration files are staged but schema file is not, warn the user
if git diff --cached --name-only | grep -qE 'migrations/.*\.php$'; then
	if ! git diff --cached --name-only | grep -q '__db_schema_data__.php'; then
		echo ""
		echo -e "${YELLOW}┌──────────────────────────────────────────────────────┐${NC}"
		echo -e "${YELLOW}│ WARNING: Migration committed without schema update   │${NC}"
		echo -e "${YELLOW}├──────────────────────────────────────────────────────┤${NC}"
		echo -e "${YELLOW}│ A migration file is staged but __db_schema_data__.  │${NC}"
		echo -e "${YELLOW}│ php is not. Consider running:                       │${NC}"
		echo -e "${YELLOW}│                                                      │${NC}"
		echo -e "${YELLOW}│   radaptor migrate:run                               │${NC}"
		echo -e "${YELLOW}│   radaptor build:db                                  │${NC}"
		echo -e "${YELLOW}│   git add generated/__db_schema_data__.php           │${NC}"
		echo -e "${YELLOW}│                                                      │${NC}"
		echo -e "${YELLOW}│ Committing anyway (this is just a warning).         │${NC}"
		echo -e "${YELLOW}└──────────────────────────────────────────────────────┘${NC}"
		echo ""
	fi
fi

exit 0
